# ==============================================================================
# LLM Benchmark Platform - Environment Configuration
# ==============================================================================
# Copy this file to .env and adjust values for your environment
# Usage: docker-compose reads .env automatically (Docker Compose v1.1.0+)

# ==============================================================================
# DATABASE CONFIGURATION
# ==============================================================================
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_USER=evaluser
POSTGRES_PASSWORD=evalpass
POSTGRES_DB=evaldb
DATABASE_URL=postgresql://evaluser:evalpass@db:5432/evaldb

# ==============================================================================
# REDIS / CELERY CONFIGURATION
# ==============================================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# ==============================================================================
# EVALSCOPE CONFIGURATION (Python SDK Mode)
# ==============================================================================
# EvalScope output directory (task results, logs, predictions)
EVALSCOPE_OUTPUT_DIR=/workspace/outputs
# EvalScope dataset directory (uploaded custom datasets)
EVALSCOPE_DATASET_DIR=/workspace/datasets

# ==============================================================================
# APPLICATION SETTINGS
# ==============================================================================
# Environment: development | production
ENVIRONMENT=production

# Secret key for JWT tokens (change in production!)
SECRET_KEY=your-secret-key-change-in-production

# LDAP: configure in Admin → Platform Settings → LDAP (stored in database)
